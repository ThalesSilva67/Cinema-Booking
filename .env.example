# ==========================================
# Configurações do Banco de Dados (PostgreSQL)
# ==========================================
# Utilizador do banco de dados (Padrão no Docker local: postgres)
DB_USER=postgres

# Palavra-passe do banco de dados
DB_PASSWORD=

# Hash BCrypt da palavra-passe do Administrador inicial (Criado pelo Flyway)
# Pode gerar um hash no site: https://bcrypt-generator.com/ (Ex: bcrypt("admin123"))
ADMIN_PASSWORD_HASH=

# ==========================================
# Segurança e Autenticação (JWT)
# ==========================================
# Chave secreta em Base64 para assinar os tokens JWT
JWT_SECRET=

# ==========================================
# Integração de Pagamentos (Stripe)
# ==========================================
# Chave secreta da API do Stripe (Começa com sk_test_...)
STRIPE_SECRET_KEY=

# Segredo de assinatura do Webhook do Stripe (Começa com whsec_...)
# Gerado ao rodar "stripe listen" ou no painel do Stripe para produção
STRIPE_WEBHOOK_SECRET=